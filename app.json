{
  "expo": {
    "name": "İzlio",
    "slug": "streaming-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "izlio",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.acebi.izlio",
      "jsEngine": "jsc",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "izlio"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.556246058284-50k1stl1ivqfqgu1sql3pfg9ucr0h04v"
            ]
          }
        ]
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "2",
      "associatedDomains": ["applinks:streaming-hub-app-tan.vercel.app"]
    },
    "android": {
      "jsEngine": "jsc",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#000000"
      },
      "package": "com.acebi.izlio"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, maximum-scale=1"
      }
    },
    "plugins": [
      ["expo-router", { "origin": "https://streaming-hub-app-tan.vercel.app" }],
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/splash.png",
          "imageWidth": 400,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "router": {
        "root": "src/app"
      },
      "eas": {
        "projectId": "ef1ef5c3-44f2-470b-b27d-fd7bd66c95be"
      }
    },
    "owner": "acebi"
  }
}
