{
  "buildCommand": "npx expo export --platform web --output-dir dist && mkdir -p dist/.well-known && cp public/.well-known/apple-app-site-association dist/.well-known/apple-app-site-association",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/.well-known/apple-app-site-association", "destination": "/.well-known/apple-app-site-association" },
    { "source": "/c/:id", "destination": "/api/c?id=:id" },
    { "source": "/u/:username", "destination": "/api/u?username=:username" },
    { "source": "/((?!\\.well-known|api|c/|u/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
